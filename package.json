{
  "name": "@yaguar/whatsapp-sdk",
  "version": "0.1.0",
  "description": "Lightweight WhatsApp Web (Baileys) SDK — no HTTP server or database bundled.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "whatsapp",
    "baileys",
    "yaguar",
    "sdk"
  ],
  "author": "Yaguar",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "async-mutex": "^0.5.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
